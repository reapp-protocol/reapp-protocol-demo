# LLM providers. At least one key is required to run the research agent.
# If BOTH are set, the agent fails over from the primary to the backup when the
# primary is out of credit or rate-limited, so it never goes dark mid-run.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional. Which provider is primary (default: anthropic). Set to "openai" to flip.
LLM_PRIMARY=anthropic

# Optional. Model ids — point these at whatever each key is provisioned for.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MODEL_SUB=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.5
OPENAI_MODEL_SUB=gpt-5.5
