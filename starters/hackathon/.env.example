# Copy the endpoint and merchant from https://reapp.live/hackathon.
# The default demo also accepts these as --endpoint and --merchant flags.
REAPP_ENDPOINT=https://reapp.live/api/express/WORKSPACE_ID/source
REAPP_MERCHANT=G_REPLACE_WITH_THE_WORKSPACE_MERCHANT

# Advanced local fulfillment example only.
PORT=4021
REAPP_PUBLIC_ORIGIN=http://127.0.0.1:4021
# Generate locally with: openssl rand -hex 32
REAPP_CHALLENGE_SECRET=replace-with-at-least-32-random-bytes
